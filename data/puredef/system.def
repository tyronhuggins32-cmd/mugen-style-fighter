;============================================================
; NEW MUGEN - PURE DEF MOTIF BASE
; Official Elecbyte M.U.G.E.N 1.0-compatible layout
; Place at: data/puredef/system.def
;============================================================

[Info]
name = "NEW MUGEN"
author = "tyronhuggins32-cmd"
versiondate = 07,14,2026
mugenversion = 1.0
localcoord = 1280,720

[Files]
; M.U.G.E.N checks this motif folder first, then data/, then root.
; These references intentionally reuse the stock M.U.G.E.N assets.
spr = system.sff
snd = system.snd
logo.storyboard =
intro.storyboard =
select = select.def
fight = fight.def
font1 = f-4x6.def
font2 = name14.def
font3 = enter48.def
font4 = arcade.def
font5 = mssansserif-tt36.def
font6 = infofont.def

[Music]
; Add sound files later. Blank values mean silence.
title.bgm =
title.bgm.volume = 100
title.bgm.loop = 1
title.bgm.loopstart =
title.bgm.loopend =

select.bgm =
select.bgm.volume = 100
select.bgm.loop = 1
select.bgm.loopstart =
select.bgm.loopend =

vs.bgm =
vs.bgm.volume = 100
vs.bgm.loop = 0
vs.bgm.loopstart =
vs.bgm.loopend =

victory.bgm =
victory.bgm.volume = 100
victory.bgm.loop = 0
victory.bgm.loopstart =
victory.bgm.loopend =

